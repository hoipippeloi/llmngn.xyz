{
  "name": "llmngn",
  "version": "0.1.0",
  "description": "$ llmngn_ - Context persistence plugin for OpenCode using LanceDB",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "llmngn": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "context",
    "persistence",
    "lancedb",
    "vector-database",
    "embedding",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@lancedb/lancedb": "^0.4.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "uuid": "^9.0.0",
    "ora": "^7.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/bun": "latest",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "postcss-load-config": "^6.0.1",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true
